{
  "connections": {
    "TableName": "apexvision-ws-connections",
    "AttributeDefinitions": [
      {"AttributeName": "connectionId", "AttributeType": "S"},
      {"AttributeName": "clientType", "AttributeType": "S"},
      {"AttributeName": "connectedAt", "AttributeType": "N"}
    ],
    "KeySchema": [
      {"AttributeName": "connectionId", "KeyType": "HASH"}
    ],
    "GlobalSecondaryIndexes": [
      {
        "IndexName": "clientType-index",
        "KeySchema": [
          {"AttributeName": "clientType", "KeyType": "HASH"},
          {"AttributeName": "connectedAt", "KeyType": "RANGE"}
        ],
        "Projection": {"ProjectionType": "ALL"}
      }
    ],
    "BillingMode": "PAY_PER_REQUEST"
  }
}
